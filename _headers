/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://app.visitortracking.com https://www.googletagmanager.com https://app.cal.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://app.visitortracking.com https://www.google-analytics.com; frame-src 'self' https://app.cal.com https://cal.com; connect-src 'self' https://enquiries.incremento.co https://app.visitortracking.com https://www.google-analytics.com https://analytics.google.com https://region1.google-analytics.com https://app.cal.com https://cal.com;

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# Images are content-hashed by filename in practice (we rename on change), so a
# long cache is right - but NOT immutable. A 404 fallback served from this path
# inherits these headers, and `immutable` pins that mistake at the edge for a
# year with no way to revalidate. One day, revalidating, is the safer trade.
/images/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
